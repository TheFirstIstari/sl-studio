{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["summary", "source_quote"],
    "properties": {
      "summary": {
        "type": "string",
        "description": "Brief description of the fact"
      },
      "category": {
        "type": "string",
        "enum": ["person", "location", "date", "event", "financial", "organization", "other"]
      },
      "severity": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "confidence": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "source_quote": {
        "type": "string",
        "description": "Exact quote from source"
      }
    }
  }
}
