{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["type", "value"],
    "properties": {
      "type": {
        "type": "string",
        "enum": ["person", "organization", "account", "amount", "location", "date", "transaction"]
      },
      "value": {
        "type": "string"
      },
      "context": {
        "type": "string"
      }
    }
  }
}
